{
  "name": "@gakwaya/app-agent-entities",
  "version": "1.3.1",
  "type": "module",
  "description": "Shared domain types for App-Agent — zero internal dependencies",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/labKnowledge/app-agent-framework.git",
    "directory": "app-agent/packages/entities"
  },
  "homepage": "https://github.com/labKnowledge/app-agent-framework/tree/main/app-agent",
  "bugs": {
    "url": "https://github.com/labKnowledge/app-agent-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
