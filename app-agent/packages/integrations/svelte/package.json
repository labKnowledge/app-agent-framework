{
  "name": "@gakwaya/app-agent-svelte",
  "version": "1.3.1",
  "type": "module",
  "description": "Svelte integration for App-Agent",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./AppAgentPanel.svelte": {
      "types": "./dist/AppAgentPanel.svelte",
      "import": "./dist/AppAgentPanel.svelte"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gakwaya/app-agent": "workspace:*",
    "@gakwaya/app-agent-entities": "workspace:*",
    "@gakwaya/app-agent-integrations-shared": "workspace:*",
    "@gakwaya/app-agent-ui": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0"
  },
  "devDependencies": {
    "svelte": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/labKnowledge/app-agent-framework.git",
    "directory": "app-agent/packages/integrations/svelte"
  },
  "homepage": "https://github.com/labKnowledge/app-agent-framework/tree/main/app-agent",
  "bugs": {
    "url": "https://github.com/labKnowledge/app-agent-framework/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
