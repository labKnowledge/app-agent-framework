{
  "name": "@app-agent/app-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Public facade for App-Agent — single consumer-facing import",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@app-agent/entities": "workspace:*",
    "@app-agent/core": "workspace:*",
    "@app-agent/semantic-registry": "workspace:*",
    "@app-agent/workflow": "workspace:*",
    "@app-agent/ui": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
