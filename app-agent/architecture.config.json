{
  "moduleBoundaries": [
    {
      "name": "entities",
      "path": "packages/entities",
      "allowedImports": ["packages/entities"],
      "forbiddenPatterns": ["@gakwaya/"]
    },
    {
      "name": "infrastructure",
      "path": "packages/(state-manager|memory|llm|tools|planner|workflow|semantic-registry)",
      "allowedImports": ["packages/entities"],
      "forbiddenPatterns": ["@gakwaya/app-agent-core", "@gakwaya/app-agent-ui", "@gakwaya/app-agent"]
    },
    {
      "name": "core",
      "path": "packages/core",
      "allowedImports": [
        "packages/entities",
        "packages/state-manager",
        "packages/memory",
        "packages/llm",
        "packages/tools",
        "packages/planner",
        "packages/workflow",
        "packages/semantic-registry",
        "packages/core"
      ],
      "forbiddenPatterns": ["@gakwaya/app-agent-ui", "@gakwaya/app-agent"]
    },
    {
      "name": "ui",
      "path": "packages/ui",
      "allowedImports": ["packages/entities", "packages/core"],
      "forbiddenPatterns": ["@gakwaya/app-agent-planner", "@gakwaya/app-agent-workflow", "@gakwaya/app-agent-memory"]
    },
    {
      "name": "facade",
      "path": "packages/app-agent",
      "allowedImports": ["packages/*"],
      "forbiddenPatterns": []
    }
  ],
  "maxMetrics": {
    "circularDependencies": 0,
    "maxEfferentCoupling": 12,
    "maxFileLength": 400,
    "maxFunctionLength": 80
  }
}
